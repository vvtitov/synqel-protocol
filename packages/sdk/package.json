{
  "name": "@synqel/sdk",
  "version": "0.1.0",
  "description": "Semantic runtime SDK — the open standard for AI-navigable web applications",
  "license": "MIT",
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./react": {
      "import": "./dist/react.js",
      "types": "./dist/react.d.ts"
    }
  },
  "files": ["dist"],
  "peerDependencies": {
    "react": ">=18",
    "zod": ">=3"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.1.3",
    "@types/react": "^19.1.2",
    "zod": "^3.24.4",
    "react": "^19.1.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vvtitov/synqel-protocol.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/vvtitov/synqel-protocol#readme",
  "bugs": {
    "url": "https://github.com/vvtitov/synqel-protocol/issues"
  },
  "keywords": [
    "ai",
    "semantic",
    "protocol",
    "agents",
    "accessibility",
    "registry",
    "sdk",
    "mcp",
    "json-schema",
    "zod"
  ],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run test && bun run build"
  },
  "dependencies": {
    "zod-to-json-schema": "^3.25.2"
  }
}
