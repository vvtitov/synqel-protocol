      "optional": true
    }
  },
  "devDependencies": {
    "typescript": "^5.7.3",
    "vitest": "^3.1.3",
    "@types/react": "^19.1.2",
    "zod": "^3.24.4",
    "react": "^19.1.0"
  },
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  }
}
